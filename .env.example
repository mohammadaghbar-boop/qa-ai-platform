# Copy this file to .env and fill in your real key. .env is gitignored — never commit it.

# Anthropic API key, used by the `claude` CLI (spawned in server.js) for non-interactive
# billing instead of an interactive login. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend API key, used to send "forgot password" reset-link emails to team members.
# Get one at https://resend.com/api-keys — without it, forgot-password requests are
# accepted but no email is actually sent (check the server log for the failure).
RESEND_API_KEY=

# "From" address for reset emails. Must be a verified sender/domain in your Resend
# account; the default onboarding@resend.dev only works for testing.
RESEND_FROM_EMAIL=QA AI Platform <onboarding@resend.dev>

# Public base URL used to build the reset-password link (e.g. https://qa.yourcompany.com).
# Leave blank to derive it from the incoming request's Host header.
APP_URL=
