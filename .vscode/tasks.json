{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start QA AI Server",
      "type": "shell",
      "command": "node server.js",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "QA AI Platform proxy is running",
          "endsPattern": "Keep this terminal open"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false
      }
    }
  ]
}
